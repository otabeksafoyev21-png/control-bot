# Telegram userbot (MTProto) — https://my.telegram.org/apps dan
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# scripts/create_session.py ishga tushirib oling
TELEGRAM_STRING_SESSION=

# Control bot (Bot API) — @BotFather dan
CONTROL_BOT_TOKEN=
# Sizning Telegram user ID (botga /start bosganingizda admin ekanligingizni
# aniqlash uchun) — masalan @userinfobot orqali biling.
OWNER_ID=

# Kaworai_bot SECRET_CHANNEL_ID — shu kanalga watcher topilgan video-ni
# post qiladi, kaworai_bot o'z handleri bilan DB-ga yozadi. Integer.
# Sizning akauntingiz shu kanalda post qila oladigan bo'lishi kerak.
SECRET_CHANNEL_ID=

# Watcher mahalliy state fayli (kanal→anime_id map, dedup)
SQLITE_PATH=watcher.db

# Parser
MIN_VIDEO_DURATION=60

LOG_LEVEL=INFO
